NODE_ENV=development
PORT=8000

STELLAR_NETWORK=testnet

TESTNET_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADX3W
MAINNET_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADX3W

CACHE_TTL_SECONDS=60
HORIZON_TIMEOUT=30000

# Required for on-chain score sync (BK-7). Must match the contract admin.
ADMIN_SECRET_KEY=

# X402 paid-endpoint configuration (BK-8..BK-11).
# Set either PAYMENT_RECEIVE_ADDRESS explicitly, or the public key of
# ADMIN_SECRET_KEY will be used.
PAYMENT_RECEIVE_ADDRESS=
PAYMENT_AMOUNT_XLM=0.5
PAYMENT_REQUEST_TTL_SECONDS=900
